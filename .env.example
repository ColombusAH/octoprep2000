# ──────────────────────────────────────────────────────────────────────
# OctoPrep2000 — env template
# Copy to .env (root) for local dev. Railway injects equivalents in prod.
# ──────────────────────────────────────────────────────────────────────

# Backend ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://octoprep:octoprep@localhost:5432/octoprep
PORT=8000

# Tikal LiteLLM gateway key + URL. Used by PPTXAgent, VisionAgent, ContentAgent.
LITELLM_API_KEY=
LITELLM_BASE_URL=https://litellm.tikalk.dev/v1

# Model for VisionAgent — analyzes video frames (images).
LITELLM_VISION_MODEL=gpt-4o
# Model for PPTXAgent + ContentAgent — text only, cheaper model is fine.
LITELLM_TEXT_MODEL=gpt-4.1-mini
# Model for AudioAgent — speech-to-text, routed through the gateway above.
LITELLM_STT_MODEL=eleven-scribe-v1

# ── Personal-key fallback providers ─────────────────────────────────────
# Used when the Tikal LiteLLM gateway is down or out of quota (e.g. on demo day).
# TO APPLY: fill in ANTHROPIC_API_KEY (and ELEVENLABS_API_KEY for STT) below, then
# set PROVIDER_MODE=direct and restart the backend (`make backend`).
# Check it took: curl localhost:8000/config → look for "provider_mode": "direct".

# Anthropic Claude — covers Vision/Content/PPTX. Get a key at console.anthropic.com.
# Blank = this fallback is disabled (gateway-only, regardless of PROVIDER_MODE).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# "auto" (default): try the Tikal gateway first, fall back to the personal-key
# providers above on error. "direct": personal-key providers go first instead
# (still falls back to the gateway if THEY fail). Flip to "direct" the moment you
# know the gateway is exhausted — no need to wait for failures to trigger it.
PROVIDER_MODE=auto

# Direct (non-gateway) ElevenLabs STT fallback for AudioAgent — Claude has no
# speech-to-text, so STT needs its own key. Needs a literal ElevenLabs account key
# (not a Tikal "sk-..." key). Blank = this fallback is disabled.
ELEVENLABS_API_KEY=

# Google Cloud Vision via Tikal LiteLLM gateway — supplemental face detection (eye contact via head angles, joy)
# Shared gateway route, no per-dev GCP credentials needed. Leave blank to skip face detection entirely.
# Has its own bearer key — NOT the same as LITELLM_API_KEY. Get it from Tomer.
LITELLM_VISION_ANNOTATE_URL=https://litellm.tikalk.dev/vision/annotate
LITELLM_VISION_ANNOTATE_API_KEY=
FACE_DETECTION_PAN_THRESHOLD_DEG=25
FACE_DETECTION_TILT_THRESHOLD_DEG=20
FACE_DETECTION_ROLL_THRESHOLD_DEG=25

# Behavioural
VISION_TIMEOUT_MS=5000
RATE_LIMIT_SESSIONS_PER_MIN=5
FRAME_DEDUP_HAMMING_THRESHOLD=8
AUDIO_CHUNK_SECONDS=2
STALE_SLIDE_SECONDS=240

# Demo insurance — set to "replay" to use canned fixtures instead of live APIs
DEMO_MODE=

# Logging — set to DEBUG for verbose agent/LLM output (default INFO)
LOG_LEVEL=INFO

# CTA
MENTOR_BOOKING_URL=https://calendly.com/tikal-experts/30min

# Frontend ────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
