# ──────────────────────────────────────────────────────────────────────
# OctoPrep2000 — env template
# Copy to .env (root) for local dev. Railway injects equivalents in prod.
# ──────────────────────────────────────────────────────────────────────

# Backend ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://octoprep:octoprep@localhost:5432/octoprep
PORT=8000

# Tikal LiteLLM gateway key + URL. Used by PPTXAgent, VisionAgent, ContentAgent.
LITELLM_API_KEY=
LITELLM_BASE_URL=https://litellm.tikalk.dev/v1

# Model for VisionAgent — analyzes video frames (images).
LITELLM_VISION_MODEL=gpt-4o
# Model for PPTXAgent + ContentAgent — text only, cheaper model is fine.
LITELLM_TEXT_MODEL=gpt-4.1-mini
# Model for AudioAgent — speech-to-text, routed through the gateway above.
LITELLM_STT_MODEL=eleven-scribe-v1

# Unused unless you have a literal ElevenLabs account key (not a Tikal "sk-..." key).
ELEVENLABS_API_KEY=

# Google Cloud Vision via Tikal LiteLLM gateway — supplemental face detection (eye contact via head angles, joy)
# Shared gateway route, no per-dev GCP credentials needed. Leave blank to skip face detection entirely.
LITELLM_VISION_ANNOTATE_URL=https://litellm.tikalk.dev/vision/annotate
FACE_DETECTION_PAN_THRESHOLD_DEG=25
FACE_DETECTION_TILT_THRESHOLD_DEG=20
FACE_DETECTION_ROLL_THRESHOLD_DEG=25

# Behavioural
VISION_TIMEOUT_MS=5000
RATE_LIMIT_SESSIONS_PER_MIN=5
FRAME_DEDUP_HAMMING_THRESHOLD=8
AUDIO_CHUNK_SECONDS=2

# Demo insurance — set to "replay" to use canned fixtures instead of live APIs
DEMO_MODE=

# CTA
MENTOR_BOOKING_URL=https://calendly.com/tikal-experts/30min

# Frontend ────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
