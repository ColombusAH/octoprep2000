# ──────────────────────────────────────────────────────────────────────
# OctoPrep2000 — env template
# Copy to .env (root) for local dev. Railway injects equivalents in prod.
# ──────────────────────────────────────────────────────────────────────

# Backend ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://octoprep:octoprep@localhost:5432/octoprep
PORT=8000

# Tikal LiteLLM (PPTX, Vision, Content, Report agents)
LITELLM_API_KEY=
LITELLM_BASE_URL=https://litelm.tikalk.dev/v1
LITELLM_VISION_MODEL=gpt-4o
LITELLM_TEXT_MODEL=gpt-4o-mini

# ElevenLabs Scribe v1 (STT)
ELEVENLABS_API_KEY=

# Google Cloud Vision — supplemental face detection (eye contact via head angles, joy)
# Path to service-account JSON; leave blank to skip face detection entirely.
# Set up: https://cloud.google.com/vision/docs/setup
GOOGLE_APPLICATION_CREDENTIALS=
FACE_DETECTION_PAN_THRESHOLD_DEG=25
FACE_DETECTION_TILT_THRESHOLD_DEG=20
FACE_DETECTION_ROLL_THRESHOLD_DEG=25

# Behavioural
VISION_TIMEOUT_MS=5000
RATE_LIMIT_SESSIONS_PER_MIN=5
FRAME_DEDUP_HAMMING_THRESHOLD=8
AUDIO_CHUNK_SECONDS=2

# Demo insurance — set to "replay" to use canned fixtures instead of live APIs
DEMO_MODE=

# CTA
MENTOR_BOOKING_URL=https://calendly.com/tikal-experts/30min

# Frontend ────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
